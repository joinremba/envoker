{
  "name": "envoker-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "start": "NODE_ENV=production bun run src/server/index.ts",
    "format": "prettier --write src/server",
    "format:check": "prettier --check src/server",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "typecheck:sdk": "cd src/sdk && node node_modules/typescript/bin/tsc --noEmit",
    "db:push": "drizzle-kit push",
    "check": "bun run typecheck && bun run typecheck:sdk"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.3.0",
    "@better-auth/drizzle-adapter": "^1.2.0",
    "@libsql/client": "^0.17.4",
    "@paralleldrive/cuid2": "^3.3.0",
    "better-auth": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
